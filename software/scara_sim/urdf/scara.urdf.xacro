<?xml version="1.0"?>
<!-- ============================================================
     SCARA URDF v3 - matches new SolidWorks export (Robot_v2)
     - joint_0 origin: 0 -0.016 0.11125 (much cleaner, near-centered)
     - joint_1 origin: 0 0.15 0.034 (along +Y)
     - Continuous joints (no limits in URDF)
     - Prismatic spindle (joint_2) added back as cylinder
     - mock_components hardware for reliable RViz visualization
     ============================================================ -->
<robot name="scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="grey">      <color rgba="0.79216 0.81961 0.93333 1"/> </material>
  <material name="light_grey"><color rgba="0.898 0.898 0.898 1"/> </material>
  <material name="mid_grey">  <color rgba="0.627 0.627 0.627 1"/> </material>
  <material name="dark_grey"> <color rgba="0.3 0.3 0.3 1"/> </material>

  <xacro:property name="mesh_pkg" value="package://scara_sim/meshes"/>

  <!-- ===================== world + base ===================== -->
  <link name="world"/>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.010371 0.070225 0.0075664" rpy="0 0 0"/>
      <mass value="1.5527"/>
      <inertia ixx="0.021844" ixy="5.164E-08" ixz="-1.9194E-08"
               iyy="0.0098114" iyz="-9.3913E-07" izz="0.03138"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/base_link.STL"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/base_link.STL"/></geometry>
    </collision>
  </link>

  <!-- ===================== link_0 (upper arm) ===================== -->
  <link name="link_0">
    <inertial>
      <origin xyz="-6.98e-07 0.05208 0.01466" rpy="0 0 0"/>
      <mass value="0.578759"/>
      <inertia ixx="0.001779" ixy="3.13E-08" ixz="-8.0E-10"
               iyy="0.000130" iyz="2.03E-07" izz="0.001890"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/link_0.STL"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/link_0.STL"/></geometry>
    </collision>
  </link>

  <!-- joint_0: base_link -> link_0 (EXACT from new SW export) -->
  <joint name="joint_0" type="revolute">
    <origin xyz="0 -0.016 0.11125" rpy="0 0 0"/>
    <parent link="base_link"/><child link="link_0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ===================== link_1 (forearm) ===================== -->
  <link name="link_1">
    <inertial>
      <origin xyz="0.01468 0.06020 0.04343" rpy="0 0 0"/>
      <mass value="1.44327"/>
      <inertia ixx="0.006026" ixy="-0.001045" ixz="0.000166"
               iyy="0.001997" iyz="0.000681" izz="0.005452"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/link_1.STL"/></geometry>
      <material name="mid_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_pkg}/link_1.STL"/></geometry>
    </collision>
  </link>

  <!-- joint_1: link_0 -> link_1 (EXACT from new SW export) -->
  <joint name="joint_1" type="revolute">
    <origin xyz="0 0.15 0.034" rpy="0 0 0"/>
    <parent link="link_0"/><child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="100" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ===================== link_2 (spindle - prismatic) ===================== -->
  <link name="link_2">
    <inertial>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.01" length="0.18"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><cylinder radius="0.01" length="0.18"/></geometry>
    </collision>
  </link>

  <!-- joint_2: prismatic spindle (positioned at the end of link_1) -->
  <joint name="joint_2" type="prismatic">
    <origin xyz="0 0.147 0" rpy="0 0 0"/>
    <parent link="link_1"/><child link="link_2"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.0" upper="0.105" effort="100" velocity="0.1"/>
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <link name="end_effector_link"/>
  <joint name="end_effector_joint" type="fixed">
    <origin xyz="0 0 -0.06" rpy="0 0 0"/>
    <parent link="link_2"/><child link="end_effector_link"/>
  </joint>

  <!-- ===================== ros2_control (mock hardware) ===================== -->
  <ros2_control name="ScaraSystem" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>
    <joint name="joint_0">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
